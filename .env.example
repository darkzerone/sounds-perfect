# -------------------------------------------------------------------
# Sounds Perfect - Railway Environment Variables (.env)
# -------------------------------------------------------------------

# 1. Port Address (Provided automatically by Railway)
PORT=3001

# 2. Security (JWT Endpoint tokens verification)
# Generate a secure 32+ character random string
JWT_SECRET=your_secure_random_hash_key_here

# 3. Admin Dashboard Authentication
# Safe passphrase for the static admin route login
ADMIN_PASSWORD=your_secure_admin_passphrase

# 4. Canonical Site URL (Used for AI agents verification)
VITE_SITE_URL=https://sounds-perfect.nl
